# Unoverse server — one host serves /mcp (definitions/theme), /stream (data-plane)
# and /execute (the REST workflow trigger).
VITE_UNOVERSE_URL=http://localhost:4205

# The app to load and self-run. The client reads its manifest
# (unoverse://apps/<id>) for the workflow binding — "it appears and works".
VITE_APP_ID=findcard

# Auth0 OIDC — the channel signs in like the rest of the platform (workbench/Canvas).
# Unset → no AuthProvider; the client talks anonymously (server DISABLE_AUTH=true).
VITE_AUTH_ISSUER=https://your-tenant.auth0.com
VITE_AUTH_CLIENT_ID=your-client-id
VITE_AUTH_AUDIENCE=gravity-api
